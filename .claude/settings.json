{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "japanese",
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(qh:*)",
      "Bash(rg:*)",
      "Bash(gemini:*)",
      "Bash(Search:*)",
      "mcp__context7"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env*)",
      "Read(**/.npmrc)",
      "Read(**/.id_rsa)",
      "Read(**/.id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Read(**/secrets/**)",
      "Write(**/.env)",
      "Write(**/.env*)",
      "Write(**/.npmrc)",
      "Write(**/.id_rsa)",
      "Write(**/.id_ed25519)",
      "Write(**/*token*)",
      "Write(**/*key*)",
      "Write(**/*secret*)",
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm remove:*)",
      "Bash(pnpm uninstall:*)",
      "Bash(pnpm remove:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(netcat:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)",
      "Bash(ftp:*)",
      "Bash(sftp:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)",
      "Bash(redis:*)",
      "Bash(sqlite:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(chgrp:*)",
      "Bash(mount:*)",
      "Bash(umount:*)",
      "Bash(systemctl:*)",
      "Bash(service:*)",
      "Bash(apt:*)",
      "Bash(brew:*)",
      "Bash(dnf:*)",
      "Bash(pacman:*)",
      "Bash(yum:*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_AUTOUPDATER": "1"
  },
  "statusLine": {
    "type": "command",
    "command": "npx ccusage@latest statusline"
  }
}
